
# TalentSuite Environment Variables
# Copy this file to .env and fill in your keys

# Stripe (get from stripe.com → Developers → API Keys)
STRIPE_SECRET_KEY=sk_test_paste_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_paste_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_paste_your_webhook_secret_here
